{
  "name": "boltline-rag-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client"
  ],
  "scripts": {
    "prepare": "test -d .git && git config core.hooksPath .githooks 2>/dev/null || true",
    "rag:ingest": "tsx src/ingest.ts",
    "rag:ask": "tsx src/query.ts",
    "dev": "concurrently -k \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "npm run dev -w boltline-rag-demo-web",
    "build:client": "npm run build -w boltline-rag-demo-web",
    "build": "npm run build:client",
    "start": "NODE_ENV=production tsx server/index.ts"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.1",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "google-auth-library": "^9.15.1",
    "openai": "^4.77.0",
    "redis": "^5.12.1"
  }
}
