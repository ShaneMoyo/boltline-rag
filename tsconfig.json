{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true
  },
  "include": [
    "shared/**/*.ts",
    "src/**/*.ts",
    "server/**/*.ts",
    "api/**/*.ts",
    "vitest.config.ts",
    "server/**/*.test.ts",
    "server/**/*.integration.test.ts",
    "src/**/*.test.ts"
  ]
}
