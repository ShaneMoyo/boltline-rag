# Required for embeddings and chat (OpenAI-compatible API)
OPENAI_API_KEY=

# Required for session encryption — generate with: openssl rand -hex 32
SESSION_SECRET=

# Required for Google Sign-In
# Get this from: console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=

# Optional: Azure OpenAI, local proxy, etc.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional model overrides (defaults shown)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_CHAT_MODEL=gpt-4o-mini
